RewriteEngine On

# Legacy URLs → renamed articles (SEO 301)
RewriteRule ^articles/summer-bodymake\.html$ /articles/grooming-guide.html [R=301,L]
RewriteRule ^articles/gym-before-summer\.html$ /articles/mens-gym-guide.html [R=301,L]

# Canonical URL: strip index.html
RewriteRule ^index\.html$ / [R=301,L]
RewriteRule ^articles/index\.html$ /articles/ [R=301,L]

# Security headers
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
